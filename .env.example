# Environment Variables Template
# Salin berkas ini ke .env.local dan lengkapi nilai variabelnya

# Database Provider Selection (pilih: 'mysql' untuk lokal atau 'supabase' untuk produksi)
DATABASE_PROVIDER=mysql

# Konfigurasi Database Lokal (MariaDB/MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_dev_db_user
DB_PASSWORD=your_dev_db_password
DB_NAME=ayp_affiliate

# Konfigurasi Database Produksi (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_secret

# Kredensial Akses Halaman Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Kunci Rahasia Sesi (Gunakan string acak minimal 32 karakter)
SESSION_SECRET=change_this_to_a_random_secret_string_min_32_chars
